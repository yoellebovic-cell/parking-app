{
  "expo": {
    "name": "ParkShell",
    "slug": "parkshell",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "parkshell",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.parkshell.app"
    },
    "android": {
      "package": "com.parkshell.app",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-location",
      "expo-notifications"
    ],
    "extra": {
      "eas": {
        "projectId": "bbba9b79-2f3a-4970-85e5-6dcfa4683a73"
      }
    }
  }
}
